// ═══════════════════════════════════════════════════════════════════════════════
// GALLERY
// ═══════════════════════════════════════════════════════════════════════════════

model GalleryImage {
  id        String    @id @default(cuid())
  src       String
  alt       String
  caption   String?
  event     String?
  category  String?
  date      DateTime?
  published Boolean   @default(true)
  order     Int       @default(0)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([deletedAt])
  @@map("gallery_images")
}
