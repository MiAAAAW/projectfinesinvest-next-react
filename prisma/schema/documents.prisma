// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENTS
// ═══════════════════════════════════════════════════════════════════════════════

model Document {
  id          String    @id @default(cuid())
  title       String
  description String?
  fileUrl     String    @map("file_url")
  fileType    String    @map("file_type")
  fileSize    String?   @map("file_size")
  category    String
  downloads   Int       @default(0)
  published   Boolean   @default(true)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Link opcional a una sub-evidencia de acreditación (1:N — muchos docs por evidencia)
  subEvidenceId String?                   @map("sub_evidence_id")
  subEvidence   AccreditationSubEvidence? @relation(fields: [subEvidenceId], references: [id], onDelete: SetNull)

  @@index([deletedAt])
  @@index([subEvidenceId])
  @@map("documents")
}
